<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="payment_provider_scb" model="payment.provider">
            <field name="name">SCB Bank</field>
            <field name="code">scb</field>
            <field name="state">disabled</field>
            <field name="image_128" type="base64" file="payment_scb/static/description/icon.png"/>

            <!-- Odoo 18 standard -->
<!--            <field name="support_tokenization">False</field>-->
<!--            <field name="support_refund">False</field>-->
<!--            <field name="support_authorization">False</field>-->

            <!-- Payment flow -->
            <field name="allow_express_checkout">False</field>
            <field name="is_published">True</field>

            <field name="available_country_ids" eval="[(6, 0, [ref('base.th')])]"/>
            <field name="available_currency_ids" eval="[(6, 0, [ref('base.THB')])]"/>
            <field name="company_id" ref="base.main_company"/>
        </record>

        <record id="payment_method_scb_qr" model="payment.method">
            <field name="name">SCB Bank QR</field>
            <field name="code">scb</field>
            <field name="image" type="base64" file="payment_scb/static/description/icon.png"/>
            <field name="sequence">10</field>
            <field name="active">True</field>
            <field name="provider_ids" eval="[(4, ref('payment_provider_scb'))]"/>

        </record>



    </data>
</odoo>
